# Copy this file to .env.local and fill in the values you have.
# The app runs on mocks/fallbacks without these, so you are never blocked.

# Anthropic — Claude per-turn analysis + final verdict (Batch 3+)
ANTHROPIC_API_KEY=

# Deepgram — speech-to-text, diarization, and text-to-speech (Batch 4+)
DEEPGRAM_API_KEY=

# Redis Stack with vector search (Batch 2). Easiest local option (no signup):
#   docker run -d --name debate-redis -p 6379:6379 redis/redis-stack:latest
REDIS_URL=redis://localhost:6379
